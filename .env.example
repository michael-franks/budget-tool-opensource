# ── Akahu API credentials (required) ──
# Create a personal app and connect your bank at https://my.akahu.nz
# Both tokens come from the Akahu developer dashboard for your app.
AKAHU_APP_TOKEN=app_token_XXXXXXXXXXXXXXXXXXXX
AKAHU_USER_TOKEN=user_token_XXXXXXXXXXXXXXXXXXXX

# ── Server ──
PORT=3000
HOST=0.0.0.0
# Where transactions.json / accounts.json / state.json are stored
DATA_DIR=./data
# How far back to fetch transactions on first run (ISO date)
INITIAL_FETCH_FROM=2024-01-01

# ── Optional: email reminder to settle the credit card ──
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=you@example.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=you@example.com
# CARD_REMINDER_TO=you@example.com
# CARD_REMINDER_LEAD_DAYS=4

# ── Optional: CORS / front-end origin (comma-separated) ──
# ALLOWED_ORIGIN=http://localhost:3000
# Public URL used in reminder emails
# APP_URL=http://localhost:3000

# ── Optional: lock the API behind Cloudflare Access (set to 1 to enable) ──
# REQUIRE_CF_ACCESS=0
# ALLOWED_EMAIL=
