# ── Akahu API credentials (OPTIONAL — you can connect in-app instead) ──
# Easiest: leave these blank and connect your bank from Settings → Bank connection
# inside the app. Or pre-configure here — create a Personal App and connect your bank
# at https://my.akahu.nz, then paste both tokens (env values take precedence over the
# in-app connection). Left unset, the app starts "not connected" until you connect.
# AKAHU_APP_TOKEN=app_token_XXXXXXXXXXXXXXXXXXXX
# AKAHU_USER_TOKEN=user_token_XXXXXXXXXXXXXXXXXXXX

# ── Server ──
PORT=3000
# Bind address. Localhost-only by default (safe). Set 0.0.0.0 to expose on your network,
# but the API has NO login — only do that behind Cloudflare Access (REQUIRE_CF_ACCESS=1)
# or a VPN. The Docker image sets 0.0.0.0 itself so the published port works.
HOST=127.0.0.1
# Where transactions.json / accounts.json / state.json are stored
DATA_DIR=./data
# How far back to fetch transactions on first run (ISO date)
INITIAL_FETCH_FROM=2024-01-01

# ── Optional: settlement-reminder timing (web push) ──
# Days before the 15th to send the "settle the card" push. Needs the VAPID keys below.
# CARD_REMINDER_LEAD_DAYS=4

# ── Optional: CORS / front-end origin (comma-separated) ──
# ALLOWED_ORIGIN=http://localhost:3000
# Public URL used in notification links / CORS
# APP_URL=http://localhost:3000

# ── Optional: lock the API behind Cloudflare Access (set to 1 to enable) ──
# REQUIRE_CF_ACCESS=0
# ALLOWED_EMAIL=

# ── Optional: web push notifications (installable PWA) ──
# Generate a keypair ONCE with:  npx web-push generate-vapid-keys
# Keep the private key secret; the public key is served to the browser.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@example.com
